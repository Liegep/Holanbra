// Holanbra Security Rules - Version 1.2
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == "admin") ||
        (request.auth.token.email != null && request.auth.token.email.matches("(?i)hello@liegepaschoalini\\.design")) ||
        (request.auth.token.email != null && request.auth.token.email.matches("(?i)slmariew@gmail\\.com")) ||
        (request.auth.token.email != null && request.auth.token.email.matches("(?i)victoriaholanbra@gmail\\.com"))
      );
    }

    // Property Validation
    function isValidProperty(data) {
      return data.name is string && data.name.size() <= 200
        && (data.price is number || data.price is int)
        && data.status in ['available', 'rented', 'reserved']
        && (data.get('image', '') is string)
        && (data.get('description', '') is string)
        && (data.get('slurl', '') is string)
        && (data.get('location', '') is string);
    }

    match /properties/{propertyId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidProperty(incoming());
      allow update: if isAdmin() && isValidProperty(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'price', 'status', 'image', 'gallery', 'description', 'slurl', 'location', 'updatedAt', 'casperletId', 'bedrooms', 'bathrooms', 'tenantName', 'tenantPassword', 'nextPayment'])
      );
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /team/{memberId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
