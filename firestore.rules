rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "hello@liegepaschoalini.design"
      );
    }

    // Property Validation
    function isValidProperty(data) {
      return data.name is string && data.name.size() <= 100
        && data.price is number && data.price >= 0
        && data.status in ['available', 'rented', 'reserved']
        && data.image is string && data.image.size() <= 1024
        && (data.get('description', '') is string)
        && (data.get('slurl', '') is string)
        && (data.get('location', '') is string)
        && (data.get('tenantName', '') is string)
        && (data.get('tenantPassword', '') is string)
        && (data.get('nextPayment', '') is string)
        && (data.get('casperletId', '') is string);
    }

    // Gallery Validation
    function isValidGalleryImage(data) {
      return data.url is string && data.url.size() <= 1024
        && (data.get('caption', '') is string)
        && data.createdAt == request.time;
    }

    // Team Validation
    function isValidTeamMember(data) {
      return data.name is string && data.name.size() <= 100
        && data.role is string && data.role.size() <= 100
        && data.bio is string && data.bio.size() <= 1000
        && data.image is string && data.image.size() <= 1024;
    }

    match /properties/{propertyId} {
      allow read: if true; // Public read for properties
      
      allow create: if isEmailVerified() && isValidId(propertyId) && isValidProperty(incoming()) && (
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time
      );
      
      allow update: if isEmailVerified() && isValidProperty(incoming()) && (
        incoming().updatedAt == request.time &&
        incoming().createdAt == existing().createdAt
      );

      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidId(imageId) && isValidGalleryImage(incoming());
      allow update: if isAdmin() && isValidGalleryImage(incoming());
      allow delete: if isAdmin();
    }

    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(memberId) && isValidTeamMember(incoming());
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
